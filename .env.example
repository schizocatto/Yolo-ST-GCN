# .env.example — copy to .env and fill in your paths
# .env is gitignored; this file is the committed template.

# Where the repo lives on this machine
REPO_DIR=/workspace/Yolo-ST-GCN

# Branch to use
BRANCH=refactor-1

# Path to Gym288 skeleton pickle (source data)
GYM288_PKL=/data/gym288_skeleton.pkl

# Path where the built Gym99 pickle will be written / read from
GYM99_PKL=/data/gym99_from_gym288.pkl

# Output directory for weights, metrics, etc.
OUT_DIR=outputs/train_run
